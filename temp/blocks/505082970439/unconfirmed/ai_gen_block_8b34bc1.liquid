{% doc %}
  @prompt
    video, https://admin.shopify.com/store/kultiv-2/content/files/58113274872135?selectedView=all, https://admin.shopify.com/store/kultiv-2/content/files/58113274872135?selectedView=all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000000;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-video-native-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div
  class="ai-video-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_file != blank %}
      {{
        block.settings.video_file
        | video_tag:
          image_size: '1100x',
          autoplay: block.settings.autoplay,
          loop: block.settings.loop,
          controls: block.settings.controls,
          muted: block.settings.muted,
          class: 'ai-video-native-' | append: ai_gen_id
      }}
    {% else %}
      <div class="ai-video-placeholder-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
        <div class="ai-video-empty-state-{{ ai_gen_id }}">
          Upload a video file from Shopify Files
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Video file",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Video file"
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Video file"
    }
  ]
}
{% endschema %}
