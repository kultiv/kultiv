{% comment %}
  KULTIV · Subscription landing (full page)
{% endcomment %}

{% schema %}
{
  "name": "KULTIV Subscription Page",
  "tag": "section",
  "class": "kultiv-subscription-page",
  "settings": [
    {
      "type": "select",
      "id": "hero_action",
      "label": "Primary action",
      "options": [
        { "value": "waitlist", "label": "Early access (email capture)" },
        { "value": "ctas", "label": "Buttons (product / pages)" }
      ],
      "default": "waitlist"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Early access"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Not a supplement.\nA system."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Built from soil upward. Designed for lifespan, not trends. Join early access — we only write when it matters."
    },
    {
      "type": "text",
      "id": "scarcity_line",
      "label": "Urgency line (optional)",
      "default": "Founding members · limited allocation",
      "info": "Leave blank to hide. Keep claims truthful and defensible."
    },
    {
      "type": "text",
      "id": "release_scope_line",
      "label": "Release / region line (optional)",
      "default": "First release: United Kingdom and Germany"
    },
    {
      "type": "header",
      "content": "Waitlist"
    },
    {
      "type": "text",
      "id": "newsletter_tags",
      "label": "Customer tags (comma-separated)",
      "default": "early-access, newsletter",
      "info": "Applied when someone signs up. Visible in Shopify Admin → Customers."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "waitlist_submit_label",
      "label": "Waitlist button label",
      "default": "Join early access"
    },
    {
      "type": "text",
      "id": "waitlist_success_message",
      "label": "Success message",
      "default": "You are on the list. We will be in touch."
    },
    {
      "type": "text",
      "id": "waitlist_subtext",
      "label": "Line under form",
      "default": "We never sell the list. Unsubscribe in one click."
    },
    {
      "type": "header",
      "content": "Buttons (when “Buttons” is selected)"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA",
      "default": "Start subscription"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA",
      "default": "Explore the science"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "No spam. Unsubscribe anytime. When we launch subscriptions, you will hear from us first."
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Save every month"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "15% off recurring orders. No codes, no chasing sales."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "KULTIV Subscription Page",
      "settings": {
        "hero_action": "waitlist",
        "headline": "Not a supplement.\nA system.",
        "intro": "Built from soil upward. Designed for lifespan, not trends.",
        "scarcity_line": "Founding members · limited allocation",
        "release_scope_line": "First release: United Kingdom and Germany"
      },
      "blocks": [
        { "type": "perk", "settings": { "title": "Founding access", "text": "First to know at launch — pricing, science drops, and allocation." } },
        { "type": "perk", "settings": { "title": "Soil-first system", "text": "Not a synthetic stack. A structured nutrition system with published standards." } },
        { "type": "perk", "settings": { "title": "UK & EU", "text": "Manufacturing and compliance built for where we ship first." } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .kultiv-subscription-page {
    --k-sub-pad: clamp(72px, 12vw, 140px);
    background: linear-gradient(180deg, var(--k-earth-2) 0%, var(--k-earth) 45%);
    color: var(--k-cream);
    padding: var(--k-sub-pad) 0 clamp(80px, 10vw, 120px);
  }

  .kultiv-subscription-page__inner {
    max-width: var(--k-max-width);
    margin-inline: auto;
    padding-inline: var(--k-gutter);
  }

  .kultiv-subscription-page__hero {
    max-width: 52rem;
    margin-bottom: clamp(48px, 8vw, 88px);
  }

  .kultiv-subscription-page__headline {
    font-family: var(--k-font-display);
    font-size: clamp(2.2rem, 5vw, 3.75rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--k-cream);
    margin: 0 0 28px;
    white-space: pre-line;
  }

  .kultiv-subscription-page__intro {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--k-muted);
    margin: 0 0 36px;
    max-width: 48ch;
  }

  .kultiv-subscription-page__scarcity {
    margin: -12px 0 10px;
    font-family: var(--k-font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--k-gold);
    max-width: 48ch;
  }

  .kultiv-subscription-page__release-scope {
    margin: 0 0 28px;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgba(240, 232, 216, 0.72);
    max-width: 48ch;
  }

  .kultiv-subscription-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 24px;
    align-items: center;
  }

  .kultiv-subscription-page__waitlist {
    margin-top: 8px;
    max-width: 36rem;
  }

  .kultiv-subscription-page__field-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: stretch;
  }

  .kultiv-subscription-page__field-row input[type='email'] {
    flex: 1 1 220px;
    min-height: 48px;
    padding: 0 18px;
    font-family: var(--k-font-body);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--k-cream);
    background: var(--k-surface);
    border: 1px solid var(--k-border-subtle);
    border-radius: var(--k-radius-md);
    outline: none;
    transition: border-color var(--k-transition);
  }

  .kultiv-subscription-page__field-row input[type='email']::placeholder {
    color: rgba(154, 145, 126, 0.85);
  }

  .kultiv-subscription-page__field-row input[type='email']:focus {
    border-color: var(--k-gold);
  }

  .kultiv-subscription-page__field-row button[type='submit'] {
    flex: 0 0 auto;
    min-height: 48px;
    padding: 0 26px;
    font-family: var(--k-font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--k-cream);
    background: var(--k-forest);
    border: 1px solid rgba(200, 169, 110, 0.35);
    border-radius: var(--k-radius-pill);
    cursor: pointer;
    transition: background var(--k-transition), border-color var(--k-transition);
  }

  .kultiv-subscription-page__field-row button[type='submit']:hover {
    background: var(--k-forest-2);
    border-color: var(--k-gold);
  }

  .kultiv-subscription-page__form-errors {
    margin-bottom: 16px;
    font-size: 0.85rem;
    color: #c9a27a;
  }

  .kultiv-subscription-page__form-success {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--k-cream);
  }

  .kultiv-subscription-page__waitlist-sub {
    margin: 16px 0 0;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--k-muted);
  }

  .kultiv-subscription-page__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 28px;
    font-family: var(--k-font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: var(--k-radius-pill);
    border: 1px solid transparent;
    transition: background var(--k-transition), color var(--k-transition), border-color var(--k-transition);
  }

  .kultiv-subscription-page__btn--primary {
    background: var(--k-forest);
    color: var(--k-cream);
    border-color: rgba(200, 169, 110, 0.35);
  }

  .kultiv-subscription-page__btn--primary:hover {
    background: var(--k-forest-2);
    border-color: var(--k-gold);
    color: var(--k-white);
  }

  .kultiv-subscription-page__btn--ghost {
    background: transparent;
    color: var(--k-muted);
    border-color: var(--k-border);
  }

  .kultiv-subscription-page__btn--ghost:hover {
    color: var(--k-cream);
    border-color: var(--k-gold);
  }

  .kultiv-subscription-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--k-border-subtle);
    border: 1px solid var(--k-border-subtle);
  }

  .kultiv-subscription-page__perk {
    background: var(--k-surface);
    padding: clamp(28px, 4vw, 40px);
  }

  .kultiv-subscription-page__perk h3 {
    font-family: var(--k-font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--k-cream);
    margin: 0 0 12px;
  }

  .kultiv-subscription-page__perk p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.75;
    color: var(--k-muted);
  }

  .kultiv-subscription-page__footnote {
    margin-top: 32px;
    font-size: 0.75rem;
    line-height: 1.6;
    color: rgba(154, 145, 126, 0.85);
    max-width: 52ch;
  }

  @media (max-width: 900px) {
    .kultiv-subscription-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="kultiv-subscription-page">
  <div class="kultiv-subscription-page__inner">
    <header class="kultiv-subscription-page__hero k-reveal">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.headline != blank %}
        <h1 class="kultiv-subscription-page__headline">{{ section.settings.headline }}</h1>
      {% endif %}
      {% if section.settings.intro != blank %}
        <p class="kultiv-subscription-page__intro">{{ section.settings.intro }}</p>
      {% endif %}
      {% if section.settings.scarcity_line != blank %}
        <p class="kultiv-subscription-page__scarcity">{{ section.settings.scarcity_line }}</p>
      {% endif %}
      {% if section.settings.release_scope_line != blank %}
        <p class="kultiv-subscription-page__release-scope">{{ section.settings.release_scope_line }}</p>
      {% endif %}
      {% if section.settings.hero_action == 'waitlist' %}
        <div class="kultiv-subscription-page__waitlist">
          {% form 'customer', class: 'kultiv-subscription-page__form' %}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.newsletter_tags | strip | escape }}">
            {% if form.posted_successfully? %}
              <p class="kultiv-subscription-page__form-success" tabindex="-1">
                {{ section.settings.waitlist_success_message }}
              </p>
            {% else %}
              {% if form.errors %}
                <div class="kultiv-subscription-page__form-errors">
                  {{ form.errors | default_errors }}
                </div>
              {% endif %}
              <div class="kultiv-subscription-page__field-row">
                <label class="visually-hidden" for="KultivWaitlistEmail-{{ section.id }}">{{ section.settings.email_placeholder }}</label>
                <input
                  id="KultivWaitlistEmail-{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  placeholder="{{ section.settings.email_placeholder | escape }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  required
                >
                <button type="submit">{{ section.settings.waitlist_submit_label | escape }}</button>
              </div>
              {% if section.settings.waitlist_subtext != blank %}
                <p class="kultiv-subscription-page__waitlist-sub">{{ section.settings.waitlist_subtext }}</p>
              {% endif %}
            {% endif %}
          {% endform %}
        </div>
      {% else %}
        <div class="kultiv-subscription-page__actions">
          {% if section.settings.cta_primary_text != blank %}
            <a
              class="kultiv-subscription-page__btn kultiv-subscription-page__btn--primary"
              href="{{ section.settings.cta_primary_url | default: routes.root_url }}"
            >
              {{ section.settings.cta_primary_text }}
            </a>
          {% endif %}
          {% if section.settings.cta_secondary_text != blank %}
            <a
              class="kultiv-subscription-page__btn kultiv-subscription-page__btn--ghost"
              href="{{ section.settings.cta_secondary_url | default: routes.all_products_collection_url }}"
            >
              {{ section.settings.cta_secondary_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="kultiv-subscription-page__grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'perk' %}
              <article class="kultiv-subscription-page__perk k-reveal" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h3>{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.footnote != blank %}
      <p class="kultiv-subscription-page__footnote">{{ section.settings.footnote }}</p>
    {% endif %}
  </div>
</div>
