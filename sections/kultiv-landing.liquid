{% comment %}
  KULTIV · Pre-launch homepage (single narrative — no product grid)
{% endcomment %}

{% schema %}
{
  "name": "KULTIV Pre-launch landing",
  "tag": "section",
  "class": "kultiv-landing",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "Complete longevity nutrition"
    },
    {
      "type": "textarea",
      "id": "hero_headline",
      "label": "Hero headline",
      "default": "Not a supplement.\nA system."
    },
    {
      "type": "textarea",
      "id": "hero_subline",
      "label": "Hero subline",
      "default": "Built from soil upward. Designed for lifespan, not trends."
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "Hero CTA label",
      "default": "Join early access"
    },
    {
      "type": "url",
      "id": "hero_cta_url",
      "label": "Hero CTA link"
    },
    {
      "type": "header",
      "content": "The problem"
    },
    {
      "type": "text",
      "id": "problem_headline",
      "label": "Headline",
      "default": "Modern nutrition is broken."
    },
    {
      "type": "textarea",
      "id": "problem_body",
      "label": "Body",
      "default": "Most supplements are engineered in labs, detached from how nutrients actually occur in nature. Optimised for trends, not biology."
    },
    {
      "type": "header",
      "content": "The approach"
    },
    {
      "type": "text",
      "id": "approach_headline",
      "label": "Section headline",
      "default": "We start where health actually begins."
    },
    {
      "type": "header",
      "content": "The system"
    },
    {
      "type": "text",
      "id": "system_headline",
      "label": "Headline",
      "default": "The daily system"
    },
    {
      "type": "textarea",
      "id": "system_body",
      "label": "Body",
      "default": "A consistent, soil-first intake designed to compound over time. Not a quick fix — a long-term biological advantage."
    },
    {
      "type": "header",
      "content": "Science positioning"
    },
    {
      "type": "text",
      "id": "science_headline",
      "label": "Headline",
      "default": "Grounded in biology."
    },
    {
      "type": "textarea",
      "id": "science_body",
      "label": "Body",
      "default": "Not marketing cycles. We publish where we stand — and evolve when the evidence moves."
    },
    {
      "type": "header",
      "content": "Final CTA"
    },
    {
      "type": "text",
      "id": "final_headline",
      "label": "Headline",
      "default": "Join the first release."
    },
    {
      "type": "textarea",
      "id": "final_subline",
      "label": "Subline",
      "default": "United Kingdom and Germany · Limited founding members"
    },
    {
      "type": "text",
      "id": "final_cta_label",
      "label": "Button label",
      "default": "Join early access"
    },
    {
      "type": "url",
      "id": "final_cta_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "approach_column",
      "name": "Approach column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Soil → Nutrient density"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Supporting line",
          "default": "Nutrient quality begins in the ground — not in a trend deck."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "KULTIV Pre-launch landing",
      "blocks": [
        {
          "type": "approach_column",
          "settings": {
            "title": "Soil → Nutrient density",
            "text": "Health begins in the ground, not the capsule."
          }
        },
        {
          "type": "approach_column",
          "settings": {
            "title": "Bioavailability over dosage",
            "text": "Absorption defines outcome."
          }
        },
        {
          "type": "approach_column",
          "settings": {
            "title": "System over products",
            "text": "Longevity is built daily, not occasionally."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% liquid
  assign hero_href = section.settings.hero_cta_url
  if hero_href == blank
    assign hero_href = '/pages/subscribe'
  endif
  assign final_href = section.settings.final_cta_url
  if final_href == blank
    assign final_href = '/pages/subscribe'
  endif
%}

<style>
  .kultiv-landing {
    --k-landing-pad: clamp(80px, 12vw, 132px);
    --kl-display-1: clamp(2.85rem, 7vw, 5rem);
    --kl-display-2: clamp(1.9rem, 3.4vw, 3.1rem);
    --kl-body-lg: clamp(1.06rem, 1.7vw, 1.22rem);
    --kl-body-sm: clamp(0.9rem, 1.2vw, 0.95rem);
    background-color: var(--k-earth);
    color: var(--k-cream);
    font-family: var(--k-font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .kultiv-landing__hero {
    position: relative;
    min-height: min(100svh, 960px);
    display: flex;
    align-items: flex-end;
    padding: var(--k-landing-pad) 0 clamp(64px, 9vw, 112px);
    overflow: hidden;
  }

  .kultiv-landing__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .kultiv-landing__hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
    filter: saturate(0.42) contrast(1.05);
    transform: scale(1.02);
  }

  .kultiv-landing__hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 70% at 50% 0%, rgba(0, 0, 0, 0.35) 0%, transparent 55%),
      linear-gradient(185deg, rgba(22, 14, 4, 0.2) 0%, rgba(22, 14, 4, 0.82) 52%, var(--k-earth) 100%);
    pointer-events: none;
  }

  .kultiv-landing__hero-fallback {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 20% 80%, rgba(31, 61, 42, 0.38) 0%, transparent 55%),
      radial-gradient(ellipse 60% 60% at 80% 20%, rgba(200, 169, 110, 0.08) 0%, transparent 50%),
      var(--k-earth-2);
  }

  .kultiv-landing__hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--k-max-width);
    margin-inline: auto;
    padding-inline: var(--k-gutter);
    padding-bottom: 4px;
  }

  .kultiv-landing__hero-rule {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, var(--k-gold), transparent);
    margin-bottom: 28px;
    opacity: 0.85;
  }

  .kultiv-landing__hero-eyebrow {
    margin-bottom: 22px;
  }

  .kultiv-landing__hero-headline {
    font-family: var(--k-font-display);
    font-size: var(--kl-display-1);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--k-cream);
    margin: 0 0 26px;
    max-width: 15ch;
    text-wrap: balance;
  }

  .kultiv-landing__hero-subline {
    font-size: var(--kl-body-lg);
    font-weight: 300;
    line-height: 1.78;
    color: rgba(240, 232, 216, 0.78);
    margin: 0 0 40px;
    max-width: 34ch;
    letter-spacing: 0.01em;
  }

  .kultiv-landing__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 36px;
    font-family: var(--k-font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--k-cream);
    background: var(--k-forest);
    border: 1px solid rgba(200, 169, 110, 0.4);
    border-radius: var(--k-radius-pill);
    text-decoration: none;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
    transition: background var(--k-transition), border-color var(--k-transition), color var(--k-transition),
      transform 0.45s cubic-bezier(0.4, 0, 0.2, 1), box-shadow var(--k-transition);
  }

  .kultiv-landing__btn:hover {
    background: var(--k-forest-2);
    border-color: var(--k-gold);
    color: var(--k-white);
    transform: translateY(-2px);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.42);
  }

  .kultiv-landing__btn:focus-visible {
    outline: 1px solid var(--k-gold);
    outline-offset: 4px;
  }

  .kultiv-landing__band {
    padding: var(--k-landing-pad) 0;
    border-top: 1px solid var(--k-border-subtle);
  }

  .kultiv-landing__band--surface {
    background-color: var(--k-surface);
  }

  .kultiv-landing__band--forest {
    background: linear-gradient(165deg, #142818 0%, var(--k-forest-2) 38%, var(--k-forest) 100%);
    border-color: rgba(200, 169, 110, 0.14);
    box-shadow: inset 0 1px 0 rgba(200, 169, 110, 0.08);
  }

  .kultiv-landing__inner {
    max-width: var(--k-max-width);
    margin-inline: auto;
    padding-inline: var(--k-gutter);
  }

  .kultiv-landing__inner--editorial {
    max-width: 40rem;
    text-align: center;
    margin-inline: auto;
  }

  .kultiv-landing__inner--editorial .kultiv-landing__body {
    margin-inline: auto;
    max-width: 48ch;
    font-size: var(--kl-body-lg);
  }

  .kultiv-landing__h2 {
    font-family: var(--k-font-display);
    font-size: var(--kl-display-2);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
    color: var(--k-cream);
    text-wrap: balance;
  }

  .kultiv-landing__body {
    font-size: var(--kl-body-sm);
    line-height: 1.88;
    color: var(--k-muted);
    margin: 0;
    max-width: 52ch;
    font-weight: 300;
  }

  .kultiv-landing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: clamp(40px, 5.5vw, 64px);
    background: var(--k-border-subtle);
    border: 1px solid var(--k-border-subtle);
  }

  .kultiv-landing__col {
    position: relative;
    background: var(--k-earth);
    padding: clamp(32px, 4.5vw, 48px) clamp(24px, 3vw, 36px);
    min-height: 100%;
    transition: background var(--k-transition-slow), transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .kultiv-landing__col::before {
    content: '';
    position: absolute;
    top: 0;
    left: 24px;
    right: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200, 169, 110, 0.35), transparent);
    opacity: 0;
    transition: opacity var(--k-transition);
  }

  .kultiv-landing__col:hover {
    background: var(--k-surface);
  }

  .kultiv-landing__col:hover::before {
    opacity: 1;
  }

  .kultiv-landing__band--surface .kultiv-landing__col {
    background: var(--k-surface-2);
  }

  .kultiv-landing__band--surface .kultiv-landing__col:hover {
    background: rgba(53, 45, 24, 0.65);
  }

  .kultiv-landing__col h3 {
    font-family: var(--k-font-display);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
    color: var(--k-cream);
  }

  .kultiv-landing__col p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.78;
    color: var(--k-muted);
    font-weight: 300;
  }

  .kultiv-landing__final {
    text-align: center;
    padding: clamp(96px, 13vw, 148px) 0;
    background: linear-gradient(180deg, var(--k-earth-2) 0%, var(--k-earth) 55%);
    border-top: 1px solid rgba(200, 169, 110, 0.18);
  }

  .kultiv-landing__final .kultiv-landing__h2 {
    margin-inline: auto;
  }

  .kultiv-landing__final-sub {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(154, 145, 126, 0.95);
    margin: 0 0 32px;
    max-width: 42rem;
    margin-inline: auto;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .kultiv-landing__grid {
      grid-template-columns: 1fr;
    }

    .kultiv-landing__inner--editorial {
      text-align: left;
    }

    .kultiv-landing__inner--editorial .kultiv-landing__body {
      margin-inline: 0;
    }

    .kultiv-landing__final {
      text-align: left;
    }

    .kultiv-landing__final .kultiv-landing__h2,
    .kultiv-landing__final-sub {
      margin-inline: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kultiv-landing__btn,
    .kultiv-landing__col {
      transition: none;
    }

    .kultiv-landing__btn:hover {
      transform: none;
    }
  }
</style>

<div class="kultiv-landing">
  <header class="kultiv-landing__hero k-reveal">
    <div class="kultiv-landing__hero-bg" aria-hidden="true">
      {% if section.settings.hero_image %}
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high' }}
      {% else %}
        <div class="kultiv-landing__hero-fallback"></div>
      {% endif %}
    </div>
    <div class="kultiv-landing__hero-inner">
      <div class="kultiv-landing__hero-rule" aria-hidden="true"></div>
      {% if section.settings.hero_eyebrow != blank %}
        <p class="eyebrow kultiv-landing__hero-eyebrow">{{ section.settings.hero_eyebrow }}</p>
      {% endif %}
      {% if section.settings.hero_headline != blank %}
        <h1 class="kultiv-landing__hero-headline">{{ section.settings.hero_headline | newline_to_br }}</h1>
      {% endif %}
      {% if section.settings.hero_subline != blank %}
        <p class="kultiv-landing__hero-subline">{{ section.settings.hero_subline }}</p>
      {% endif %}
      {% if section.settings.hero_cta_label != blank %}
        <a class="kultiv-landing__btn" href="{{ hero_href }}">{{ section.settings.hero_cta_label }}</a>
      {% endif %}
    </div>
  </header>

  <section class="kultiv-landing__band kultiv-landing__band--surface k-reveal">
    <div class="kultiv-landing__inner kultiv-landing__inner--editorial">
      {% if section.settings.problem_headline != blank %}
        <h2 class="kultiv-landing__h2">{{ section.settings.problem_headline }}</h2>
      {% endif %}
      {% if section.settings.problem_body != blank %}
        <p class="kultiv-landing__body">{{ section.settings.problem_body }}</p>
      {% endif %}
    </div>
  </section>

  <section class="kultiv-landing__band k-reveal">
    <div class="kultiv-landing__inner">
      {% if section.settings.approach_headline != blank %}
        <h2 class="kultiv-landing__h2">{{ section.settings.approach_headline }}</h2>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="kultiv-landing__grid">
          {% for block in section.blocks %}
            {% if block.type == 'approach_column' %}
              <div class="kultiv-landing__col" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h3>{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>

  <section class="kultiv-landing__band kultiv-landing__band--surface k-reveal">
    <div class="kultiv-landing__inner kultiv-landing__inner--editorial">
      {% if section.settings.system_headline != blank %}
        <h2 class="kultiv-landing__h2">{{ section.settings.system_headline }}</h2>
      {% endif %}
      {% if section.settings.system_body != blank %}
        <p class="kultiv-landing__body">{{ section.settings.system_body }}</p>
      {% endif %}
    </div>
  </section>

  <section class="kultiv-landing__band kultiv-landing__band--forest k-reveal">
    <div class="kultiv-landing__inner">
      {% if section.settings.science_headline != blank %}
        <h2 class="kultiv-landing__h2">{{ section.settings.science_headline }}</h2>
      {% endif %}
      {% if section.settings.science_body != blank %}
        <p class="kultiv-landing__body">{{ section.settings.science_body }}</p>
      {% endif %}
    </div>
  </section>

  <section class="kultiv-landing__final k-reveal">
    <div class="kultiv-landing__inner">
      {% if section.settings.final_headline != blank %}
        <h2 class="kultiv-landing__h2">{{ section.settings.final_headline }}</h2>
      {% endif %}
      {% if section.settings.final_subline != blank %}
        <p class="kultiv-landing__final-sub">{{ section.settings.final_subline }}</p>
      {% endif %}
      {% if section.settings.final_cta_label != blank %}
        <a class="kultiv-landing__btn" href="{{ final_href }}">{{ section.settings.final_cta_label }}</a>
      {% endif %}
    </div>
  </section>
</div>
